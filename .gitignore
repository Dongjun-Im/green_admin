# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
.venv*/
venv/
env/

# PyInstaller build artifacts
build/
dist/
dist_*/

# 릴리스 산출물 (무설치 ZIP / Inno Setup 설치 EXE) — GitHub Releases 에만 올림
release/
installer_out/
*_portable.zip
*_setup.exe

# Sensitive runtime data — DO NOT COMMIT
# - data/dumps/: 관리자 페이지 HTML 덤프 (회원 개인정보 포함)
# - data/logs/: 작업 로그 (회원 식별 정보 포함)
# - data/last_run.json: 런타임 상태
# - backups/: 우수회원 명단, 장기미접속 조정 계획 (개인정보)
data/dumps/
data/logs/
data/last_run.json
backups/

# v0.4 + 신규 사용자 데이터 — 모두 회원 식별 정보 포함
data/level_history.db
data/member_notes.db
data/undo_stack.json
data/pending_seen.json
data/admin_flags.json
data/inactivity_withdrawn.json
# 자료실(NAS) 접속 로그 — 회원 IP·접속·파일 동작 기록 포함 (개인정보)
data/nas_access_log.db

# Sensitive user credentials (if green_auth writes here)
data/credentials.ini

# 자료실 구독비 관리 — 토스 거래내역(실명·계좌 포함) 및 결제 SQLite
data/samples/
data/payments.db
# Google Sheets OAuth 토큰
data/google_token.json
data/google_credentials.json
data/sheets_config.json
# DSM(Synology) 관리자 자격증명 (암호화 저장)
data/dsm_credentials.ini

# IDE / 도구 로컬 설정
.vscode/
.idea/
.claude/
*.swp

# OS
Thumbs.db
.DS_Store
